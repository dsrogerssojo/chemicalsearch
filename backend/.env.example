# Local backend settings
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500

# Power Automate HTTP trigger URL. Create the flow first, then paste the URL here.
POWER_AUTOMATE_WEBHOOK_URL=
POWER_AUTOMATE_SHARED_SECRET=change-this-submit-secret

# Callback secret. Power Automate must send this in the x-review-secret header.
REVIEW_CALLBACK_SECRET=change-this-review-secret

# Optional: GitHub commit-back settings for approved chemicals.
# For local testing, approved chemicals are saved to backend/data/approved-chemicals.json even without GitHub.
GITHUB_TOKEN=
GITHUB_REPO=dsrogerssojo/chemicalsearch
GITHUB_APPROVED_FILE=chemicalsearch-site/sds-approved.js
GITHUB_BRANCH=main

# Optional SDS search providers for product-specific SDS lookup.
BRAVE_SEARCH_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
